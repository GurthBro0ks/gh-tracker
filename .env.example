# Phase 0 placeholder values only.
GH_TRACKER_DATA_MODE=demo
GH_TRACKER_REFRESH_INTERVAL_SECONDS=60

# Auth bridge session secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))")
HABITAT_SESSION_SECRET=change-me-to-a-32-plus-byte-random-string
HABITAT_SESSION_MAX_AGE_SECONDS=86400

# Slimy auth base URL (for server-to-server credential verification)
SLIMY_AUTH_BASE_URL=https://slimyai.xyz
